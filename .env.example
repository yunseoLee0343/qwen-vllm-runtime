# Model
MODEL_PATH=/models/qwen3.6
SERVED_MODEL_NAME=qwen3.6

# vLLM server
VLLM_HOST=0.0.0.0
VLLM_PORT=8000

# Runtime tuning
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192
DTYPE=auto
TENSOR_PARALLEL_SIZE=1

# Optional: override host port exposed on RunPod (default same as VLLM_PORT)
HOST_PORT=8000

# Optional: model root on host (mounted into /models inside container)
MODEL_ROOT=/workspace/models

# Optional auth/proxy layer, not directly supported by bare vLLM
API_KEY=
